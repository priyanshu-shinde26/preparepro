rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Top-level users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Nested collections under user doc (like quiz_results, aptitude_results)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow read access everywhere else for authenticated users (like leaderboard)
    match /{document=**} {
      allow read: if request.auth != null;
    }
  }
}
